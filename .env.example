# ============================================================
# Paris Imóveis — Conversão n8n → LangGraph (Next.js + Vercel)
# Copie este arquivo para .env.local e preencha os valores.
# Nunca commite .env.local (já está no .gitignore).
# Em produção, defina estas variáveis no painel da Vercel.
# ============================================================

# ---------- OpenAI ----------
# Modelo principal do agente "Secretária v3" (Andrézinho).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
# Modelo rápido para formatação de texto / split de mensagens / SSML.
OPENAI_MODEL_FAST=gpt-4.1-mini

# ---------- Chatwoot ----------
# Base URL com barra no final, igual ao Info.url_chatwoot do n8n.
CHATWOOT_URL=https://app.parisimoveisgoianesia.com.br/
# API token de uma conta agente ou bot do Chatwoot.
CHATWOOT_API_TOKEN=
# ID da account (geralmente 1) — igual a $json.body.account.id.
CHATWOOT_ACCOUNT_ID=1
# ID da conversa interna onde o bot envia alertas ao gestor.
CHATWOOT_ID_CONVERSA_ALERTA=1
# Webhook HMAC secret (defina no Chatwoot e cole aqui — usado para validar
# assinatura X-Chatwoot-Signature no webhook). Opcional.
CHATWOOT_WEBHOOK_SECRET=

# ---------- Supabase (já existe no projeto) ----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — usada server-side para bypassing RLS nas tabelas
# n8n_fila_mensagens, n8n_historico_mensagens, n8n_status_atendimento.
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Postgres direto (opcional) ----------
# Connection string do Supabase Postgres (Settings → Database → Connection string).
# Recomendado: usar o pooler "Transaction" mode para serverless.
POSTGRES_CONNECTION_STRING=

# ---------- Google Calendar (Service Account) ----------
# Conteúdo do JSON da Service Account codificado em base64.
# Gere com: base64 -i service-account.json | pbcopy
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=
# Email da Service Account (xxx@<project>.iam.gserviceaccount.com).
# Compartilhe os calendários com este email no Google Calendar.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# ID do calendário principal de agendamento de visitas.
GOOGLE_CALENDAR_AGENDA_ID=

# Duração padrão das visitas (em minutos).
AGENDAMENTO_DURACAO_MINUTOS=30
# Horário de atendimento por dia (0=domingo..6=sábado). Opcional — se vazio,
# usa o padrão Seg-Sex 08:00-18:00, Sáb 08:00-12:00, Dom fechado.
BUSINESS_HOURS_JSON=

# ---------- Comportamento do agente ----------
# Debounce (ms) para agrupar mensagens consecutivas antes de responder.
DEBOUNCE_MS=3000
# Se "true" (default), o agente só responde em conversas com a label
# "testando-agente" (envie /teste na conversa para habilitar). Coloque
# "false" para liberar o atendimento a todos os contatos.
REQUIRE_TEST_LABEL=true

# ---------- Google AI (Gemini para transcrição de áudio) ----------
GOOGLE_AI_API_KEY=
GEMINI_AUDIO_MODEL=models/gemini-2.5-flash

# ---------- ElevenLabs (TTS — opcional, áudio do agente) ----------
# Se não preenchido, o agente envia apenas texto (fallback automático).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=SOYHLrjzK2X1ezoPC6cr
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# ---------- Langfuse (Observability) ----------
# Opcional. Sem isso, o handler retorna undefined (zero overhead).
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com

# ---------- Vercel Cron Secret ----------
# Header secret que protege /api/cron/* e /api/agent/test contra invocação externa.
# A Vercel envia automaticamente Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=

# ---------- App ----------
# URL pública do site (usada pelo agente para construir URLs de imóveis).
APP_URL=https://www.parisimoveisgoianesia.com.br
# Nível de log (trace|debug|info|warn|error|fatal).
LOG_LEVEL=info
# Habilita áudio TTS (true|false). Default false enquanto ElevenLabs não validado.
ENABLE_AUDIO_RESPONSES=false
